# Copy to .env and fill in
SECRET_KEY=generate-a-long-random-string-here
POSTGRES_PASSWORD=generate-another-random-string

# Choose one: anthropic, openai, deepseek
GENERATION_PROVIDER=anthropic

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI
OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=

# DeepSeek
DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_GENERATION_MODEL=deepseek-v4-pro
DEEPSEEK_GENERATION_MODEL_HQ=deepseek-v4-pro
DEEPSEEK_THINKING_ENABLED=1
DEEPSEEK_REASONING_EFFORT=max

# Optional overrides:
# GENERATION_MODEL=claude-haiku-4-5
# GENERATION_MODEL_HQ=claude-sonnet-4-6
# OPENAI_GENERATION_MODEL=gpt-4o-mini
# OPENAI_GENERATION_MODEL_HQ=gpt-4o
# UPLOAD_UNLOCK_CODE=Ilovequizforge
# MAX_UPLOAD_MB=25
# MAX_PAGES=150
